<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/shift_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/clock_shell_padding_horizontal"
        android:paddingEnd="@dimen/clock_shell_padding_horizontal"
        android:paddingTop="@dimen/clock_shell_padding_top"
        android:paddingBottom="@dimen/clock_shell_padding_bottom">

        <FrameLayout
            android:id="@+id/pages_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/clock_footer_margin_top">

            <TextView
                android:id="@+id/page_indicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#707070"
                android:textSize="@dimen/clock_footer_indicator_text_size"
                android:text="" />

            <TextView
                android:id="@+id/battery_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D0D0D0"
                android:textSize="@dimen/clock_footer_battery_text_size"
                android:gravity="center"
                android:text="" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#707070"
                android:textSize="@dimen/clock_footer_status_text_size"
                android:gravity="end"
                android:text="" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
