<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/shift_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/clock_shell_padding_horizontal"
        android:paddingEnd="@dimen/clock_shell_padding_horizontal"
        android:paddingTop="@dimen/clock_shell_padding_top"
        android:paddingBottom="@dimen/clock_shell_padding_bottom">

        <LinearLayout
            android:id="@+id/global_header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_top_button_size"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/clock_header_side_inset"
            android:paddingEnd="@dimen/clock_header_side_inset">

            <TextView
                android:id="@+id/browse_place_label"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:textColor="#D0D0D0"
                android:textSize="@dimen/home_meta_text_size" />

            <TextView
                android:id="@+id/electricity_price_text"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="2dp"
                android:textColor="#D0D0D0"
                android:textStyle="bold"
                android:textSize="@dimen/home_meta_text_size"
                android:text=""
                android:visibility="gone" />

            <TextView
                android:id="@+id/nav_koti"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/nav_koti"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="@dimen/home_meta_text_size" />

            <TextView
                android:id="@+id/nav_forecast"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/nav_forecast"
                android:textColor="#808080"
                android:textStyle="bold"
                android:textSize="@dimen/home_meta_text_size" />

            <TextView
                android:id="@+id/nav_radar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/nav_radar"
                android:textColor="#808080"
                android:textStyle="bold"
                android:textSize="@dimen/home_meta_text_size" />

            <TextView
                android:id="@+id/nav_electricity"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/nav_electricity"
                android:textColor="#808080"
                android:textStyle="bold"
                android:textSize="@dimen/home_meta_text_size" />

            <ImageButton
                android:id="@+id/favorite_button"
                android:layout_width="@dimen/home_top_button_size"
                android:layout_height="@dimen/home_top_button_size"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_favorite_toggle"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_heart_outline_24"
                app:tint="#D0D0D0" />

            <ImageButton
                android:id="@+id/browse_place_button"
                android:layout_width="@dimen/home_top_button_size"
                android:layout_height="@dimen/home_top_button_size"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_browse_place"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_search_24"
                app:tint="#D0D0D0" />

            <ImageButton
                android:id="@+id/home_place_button"
                android:layout_width="@dimen/home_top_button_size"
                android:layout_height="@dimen/home_top_button_size"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_return_home_place"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_home_24"
                android:visibility="gone"
                app:tint="#D0D0D0" />

            <TextView
                android:id="@+id/page_indicator_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:gravity="center"
                android:textColor="#808080"
                android:textSize="@dimen/home_meta_text_size"
                android:text="" />

            <ImageButton
                android:id="@+id/system_button"
                android:layout_width="@dimen/home_top_button_size"
                android:layout_height="@dimen/home_top_button_size"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_system"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_system_24"
                app:tint="#D0D0D0" />

            <ImageButton
                android:id="@+id/settings_button"
                android:layout_width="@dimen/home_top_button_size"
                android:layout_height="@dimen/home_top_button_size"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_open_settings"
                android:padding="10dp"
                android:scaleType="center"
                android:src="@drawable/ic_settings_24"
                app:tint="#D0D0D0" />
        </LinearLayout>

        <View
            android:id="@+id/header_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="2dp"
            android:background="#404040" />

        <FrameLayout
            android:id="@+id/pages_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:id="@+id/footer_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/clock_footer_margin_top"
            android:background="#404040" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/clock_footer_margin_top">

            <TextView
                android:id="@+id/battery_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="@dimen/clock_footer_battery_text_size"
                android:autoSizeStepGranularity="1sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="@dimen/clock_footer_side_inset"
                android:textColor="#D0D0D0"
                android:textSize="@dimen/clock_footer_battery_text_size"
                android:gravity="start|center_vertical"
                android:text="" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="10sp"
                android:autoSizeMaxTextSize="@dimen/clock_footer_status_text_size"
                android:autoSizeStepGranularity="1sp"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingEnd="@dimen/clock_footer_side_inset"
                android:textColor="#707070"
                android:textSize="@dimen/clock_footer_status_text_size"
                android:gravity="end|center_vertical"
                android:text="" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
