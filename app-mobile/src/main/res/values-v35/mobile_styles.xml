<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MobileTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">@bool/mobile_light_status_bar</item>
        <item name="android:windowLightNavigationBar">@bool/mobile_light_status_bar</item>
        <item name="android:navigationBarColor">@color/mobile_bg</item>
        <item name="android:statusBarColor">@color/mobile_bg</item>
        <item name="android:colorAccent">@color/mobile_accent</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>

    <style name="MobileSettingsTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="android:windowBackground">@color/mobile_bg</item>
        <item name="android:colorBackground">@color/mobile_bg</item>
        <item name="android:windowLightStatusBar">@bool/mobile_light_status_bar</item>
        <item name="android:windowLightNavigationBar">@bool/mobile_light_status_bar</item>
        <item name="android:navigationBarColor">@color/mobile_bg</item>
        <item name="android:statusBarColor">@color/mobile_bg</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
