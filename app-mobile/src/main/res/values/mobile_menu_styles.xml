<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MobileMenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/mobile_menu_item_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/mobile_text_primary</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="MobileSubMenuItem" parent="MobileMenuItem">
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:paddingStart">34dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="MobileMenuSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:textColor">@color/mobile_text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
