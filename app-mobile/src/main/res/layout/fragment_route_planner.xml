<?xml version="1.0" encoding="utf-8"?>
<!-- Reittihaku (HSL): Mistä/Minne (geokoodaus) + aikavalinta → planConnection-reitit.
     MobileMainActivityn sisäinen sektio (sama ☰-header), kuten Joukkoliikenne. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobile_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Hakukortti: Mistä/Minne + swap + aika + hae -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mobile_nav_surface"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/route_from"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/mobile_card_bg"
                        android:hint="Mistä"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:textColor="@color/mobile_text_primary"
                        android:textColorHint="@color/mobile_text_muted"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/route_to"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/mobile_card_bg"
                        android:hint="Minne (esim. Rautatieasema, osoite)"
                        android:inputType="text"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:textColor="@color/mobile_text_primary"
                        android:textColorHint="@color/mobile_text_muted"
                        android:textSize="15sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/route_swap"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Vaihda suunta"
                    android:gravity="center"
                    android:text="⇅"
                    android:textColor="@color/mobile_accent"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/route_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/mobile_menu_item_bg"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp"
                    android:text="Lähde nyt"
                    android:textColor="@color/mobile_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/route_search"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/mobile_transit_badge_bg"
                    android:backgroundTint="@color/mobile_accent"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="12dp"
                    android:text="Hae reitit"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/route_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:padding="28dp"
            android:textColor="@color/mobile_text_muted"
            android:textSize="15sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/route_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="20dp"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- Reitin osat -overlay (legs). Oma header takaisin-napilla. -->
    <LinearLayout
        android:id="@+id/route_detail_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/mobile_bg"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/mobile_toolbar_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/route_detail_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Takaisin"
                android:padding="12dp"
                android:src="@drawable/mobile_ic_arrow_back" />

            <TextView
                android:id="@+id/route_detail_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Reitti"
                android:textColor="@color/mobile_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/route_detail_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mobile_nav_surface"
            android:lineSpacingExtra="2dp"
            android:padding="14dp"
            android:textColor="@color/mobile_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/route_detail_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="20dp"
            android:scrollbars="vertical" />
    </LinearLayout>
</FrameLayout>
