<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="44dp"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <View
        android:id="@+id/transit_tl_dot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/mobile_transit_dot" />

    <TextView
        android:id="@+id/transit_tl_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:textColor="@color/mobile_text_body"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/transit_tl_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/mobile_text_muted"
        android:textSize="13sp" />
</LinearLayout>
