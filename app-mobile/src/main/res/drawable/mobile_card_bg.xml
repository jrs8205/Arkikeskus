<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Hienovarainen alavarjo: näkyy vaaleassa teemassa, tummassa sulautuu mustaan taustaan.
         Drawable-pohjainen, ei vaadi elevation/clip-muutoksia layouteihin. -->
    <item android:left="2dp" android:right="2dp" android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#10000000" />
            <corners android:radius="13dp" />
        </shape>
    </item>
    <item android:left="1dp" android:right="1dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#18000000" />
            <corners android:radius="13dp" />
        </shape>
    </item>
    <!-- Kortti -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/mobile_card_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/mobile_card_stroke" />
            <corners android:radius="12dp" />
            <padding
                android:bottom="14dp"
                android:left="14dp"
                android:right="14dp"
                android:top="14dp" />
        </shape>
    </item>
</layer-list>
